# Copy this file to .env and fill in the values.
# Get credentials from 1Password > "hi-copilot OAuth Apps"
# .env is gitignored — never commit it.

# Google (Drive, Docs, Sheets, Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vanilla Knowledge Base
VANILLA_API_KEY=

# Snowflake — set via `npm run setup` (stored in ~/.copilot/tokens.json)
